# Copy this file to .env for local development, or set these as real
# environment variables / secrets on whatever host you deploy to.

# From @BotFather -> /newbot (or /mybots -> your bot -> API Token)
BOT_TOKEN=123456789:AAExampleTokenReplaceThisWithYourRealBotToken

# The public HTTPS URL this server will be reachable at once deployed.
# Used to auto-register the Telegram webhook on startup.
PUBLIC_URL=https://your-backend-host.example.com

# Any long random strings — generate with: openssl rand -hex 24
WEBHOOK_SECRET_PATH=change-me-to-a-long-random-string
WEBHOOK_SECRET_TOKEN=change-me-to-a-different-long-random-string
SESSION_SECRET=change-me-to-another-long-random-string

# Password for the /admin dashboard. Choose something strong — it protects
# real revenue and user data.
ADMIN_PASSWORD=change-me

# Restrict which origin(s) may call the API. Set to your GitHub Pages URL
# (no trailing slash) once deployed, e.g. https://wealthia.github.io
CORS_ORIGIN=*

PORT=3000
DB_PATH=./data/merge-arena.sqlite
